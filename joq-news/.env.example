# WordPress REST API base URL (no trailing slash)
EXPO_PUBLIC_WP_BASE_URL=https://your-wordpress-site.com

# Optional: Posts per page (default 10)
EXPO_PUBLIC_POSTS_PER_PAGE=10

# Firebase Auth (get from Firebase Console > Project Settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth (for social login)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=
